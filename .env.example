# ── Database ──────────────────────────────────────────────────────────────────
# Password for the Postgres container. Choose a strong random string.
POSTGRES_PASSWORD=change_me

# ── URLs ─────────────────────────────────────────────────────────────────────
# Public URL of the API (used by the auth library and CORS).
API_URL=http://localhost:8080

# Public URL of the app (React UI). Used in CORS allowed origins.
APP_URL=http://localhost:3000

# Public URL of the marketing website. Used in CORS allowed origins.
WEBSITE_URL=http://localhost:4000

# ── Email — optional ─────────────────────────────────────────────────────────
# If RESEND_API_KEY is set, emails are sent via Resend (https://resend.com).
# If omitted, email URLs are printed to the API container's stdout instead.
RESEND_API_KEY=
# The "from" address used in outgoing emails. Must be a verified sender in Resend.
EMAIL_FROM=Uppler <noreply@example.com>

# ── AI (Braintrust) ───────────────────────────────────────────────────────────
# https://braintrust.dev — project for routing LLM calls.
# See prompts/README.md for how to set up each prompt in your Braintrust project.
BRAINTRUST_API_KEY=
BRAINTRUST_PROJECT_ID=
BRAINTRUST_PROJECT_NAME=

# Slugs for each prompt — create these in your Braintrust project first.
BRAINTRUST_SLUG_IS_VALID_RESUME=
BRAINTRUST_SLUG_CORE_RESUME_EXTRACTION=
BRAINTRUST_SLUG_EXTRACT_SKILLS=
BRAINTRUST_SLUG_RESUME_MODERATION=
BRAINTRUST_SLUG_RESUME_PROJECTS_EXTRACTION=
BRAINTRUST_SLUG_JOB_DESCRIPTION_MODERATION=
BRAINTRUST_SLUG_JOB_DESCRIPTION_SKILLS_EXTRACTION=
BRAINTRUST_SLUG_ROADMAP_CURRICULUM=

# ── File Storage (Cloudflare R2) ──────────────────────────────────────────────
# Used for CV/resume uploads. Create a bucket in Cloudflare R2.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=
CLOUDFLARE_STORAGE_BUCKET=
