---
---

<section id="cta" class="bg-apricot py-[120px]">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="mx-auto max-w-2xl text-center">

      <p class="mb-4 text-sm font-medium uppercase tracking-widest text-orange">
        Get Started
      </p>
      <h2 class="mb-6 text-[48px] font-semibold leading-[1.1] tracking-tight text-navy">
        Stop guessing what to learn next.
      </h2>
      <p class="mb-10 text-lg leading-relaxed text-navy/60">
        Get clarity on your skill gaps and follow a structured roadmap toward
        your target role. Create a free account and start in minutes — no
        credit card required.
      </p>

      <a
        href="https://github.com/samipsamip/uppler"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 rounded-xl bg-navy px-8 py-4 text-base font-semibold text-white shadow-lg shadow-navy/20 transition-all hover:shadow-xl hover:shadow-navy/30 hover:-translate-y-px"
      >
        <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        Self-host on GitHub
      </a>

      <div class="mt-8 flex items-center justify-center gap-6 text-sm text-navy/40">
        <span>Clone the repo</span>
        <span class="size-1 rounded-full bg-navy/20"></span>
        <span>Copy .env.example</span>
        <span class="size-1 rounded-full bg-navy/20"></span>
        <span>docker compose up</span>
        <span class="size-1 rounded-full bg-navy/20"></span>
        <span>Get your roadmap</span>
      </div>

      <p class="mt-6 text-sm text-navy/40">
        Open source. Free to self-host. Docker Compose setup included.
      </p>

    </div>
  </div>
</section>
