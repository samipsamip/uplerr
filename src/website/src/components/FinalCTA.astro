---
---

<section id="waitlist" class="bg-apricot py-[120px]">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="mx-auto max-w-2xl text-center">

      <p class="mb-4 text-sm font-medium uppercase tracking-widest text-orange">
        Early Access
      </p>
      <h2 class="mb-6 text-[48px] font-semibold leading-[1.1] tracking-tight text-navy">
        Stop guessing what to learn next.
      </h2>
      <p class="mb-10 text-lg leading-relaxed text-navy/60">
        Get clarity on your skill gaps and follow a structured roadmap toward
        your target role. Create an account and we'll review your access — no
        credit card required.
      </p>

      <a
        href="https://app.uplerr.com/signup"
        class="inline-flex items-center justify-center rounded-xl bg-orange px-8 py-4 text-base font-semibold text-white shadow-lg shadow-orange/20 transition-all hover:shadow-xl hover:shadow-orange/30 hover:-translate-y-px"
      >
        Create Your Account
      </a>

      <div class="mt-8 flex items-center justify-center gap-6 text-sm text-navy/40">
        <span>Sign up</span>
        <span class="size-1 rounded-full bg-navy/20"></span>
        <span>Verify your email</span>
        <span class="size-1 rounded-full bg-navy/20"></span>
        <span>Wait for approval</span>
        <span class="size-1 rounded-full bg-navy/20"></span>
        <span>Get access</span>
      </div>

      <p class="mt-6 text-sm text-navy/40">
        Free to use. Invite-only access. New users are admitted gradually.
      </p>

    </div>
  </div>
</section>
