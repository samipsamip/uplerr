---
---

<section id="waitlist" class="bg-apricot py-[120px]">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="mx-auto max-w-2xl text-center">

      <p class="mb-4 text-sm font-medium uppercase tracking-widest text-orange">
        Early Access
      </p>
      <h2 class="mb-6 text-[48px] font-semibold leading-[1.1] tracking-tight text-navy">
        Stop guessing what to learn next.
      </h2>
      <p class="mb-10 text-lg leading-relaxed text-navy/60">
        Get clarity on your skill gaps and follow a structured roadmap toward
        your target role. Free to use. Invite-only access.
      </p>

      <!-- Form state -->
      <div id="waitlist-form-wrap" class="mx-auto max-w-md">
        <div class="flex overflow-hidden rounded-xl border border-orange/20 bg-white shadow-lg shadow-navy/[0.06] focus-within:border-orange/40 focus-within:shadow-xl focus-within:shadow-navy/[0.08] transition-all">
          <input
            id="waitlist-email"
            type="email"
            placeholder="Enter your email address"
            autocomplete="email"
            class="flex-1 bg-transparent px-5 py-4 text-sm text-navy placeholder:text-muted outline-none"
          />
          <button
            id="waitlist-btn"
            onclick="submitWaitlist()"
            class="m-1.5 shrink-0 rounded-lg bg-orange px-5 py-2.5 text-sm font-semibold text-white transition-all hover:opacity-90 active:scale-95"
          >
            Request Access
          </button>
        </div>
        <p id="waitlist-error" class="mt-3 hidden text-sm text-red-500"></p>
      </div>

      <!-- Success state -->
      <div id="waitlist-success" class="mx-auto hidden max-w-md">
        <div class="flex flex-col items-center gap-3 rounded-xl border border-green-200 bg-white px-6 py-5 shadow-sm">
          <div class="flex size-10 items-center justify-center rounded-full bg-green-100">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M3.5 9l4 4 7-7" stroke="#16a34a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-navy">You're on the list.</p>
            <p class="mt-1 text-sm text-muted">We'll send your invite as spots open up.</p>
          </div>
        </div>
      </div>

      <p class="mt-5 text-sm text-navy/40">
        No credit card required. No spam. Unsubscribe anytime.
      </p>

    </div>
  </div>
</section>

<script>
  async function submitWaitlist() {
    const emailEl = document.getElementById('waitlist-email') as HTMLInputElement;
    const errorEl = document.getElementById('waitlist-error') as HTMLElement;
    const btn = document.getElementById('waitlist-btn') as HTMLButtonElement;
    const email = emailEl?.value.trim();

    errorEl.classList.add('hidden');

    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      errorEl.textContent = 'Please enter a valid email address.';
      errorEl.classList.remove('hidden');
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Joining…';

    try {
      const res = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/waitlist`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error((data as { message?: string }).message ?? 'Something went wrong. Please try again.');
      }

      document.getElementById('waitlist-form-wrap')!.classList.add('hidden');
      document.getElementById('waitlist-success')!.classList.remove('hidden');
    } catch (err) {
      errorEl.textContent = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
      errorEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Request Access';
    }
  }

  (window as unknown as { submitWaitlist: () => void }).submitWaitlist = submitWaitlist;
</script>
