---
---

<section id="skill-gap" class="bg-white py-[120px]">
  <div class="mx-auto max-w-[1200px] px-6">

    <div class="mb-16 flex flex-col gap-4">
      <p class="text-sm font-medium uppercase tracking-widest text-orange">Skill Gap Analysis</p>
      <h2 class="max-w-2xl text-[42px] font-semibold leading-[1.1] tracking-tight text-navy">
        Know exactly what stands between you and the role you want.
      </h2>
    </div>

    <!-- Comparison grid -->
    <div class="mb-10 grid gap-4 lg:grid-cols-3">

      <!-- Current Skills -->
      <div class="rounded-2xl border border-[#e8eaed] bg-surface p-6">
        <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-muted">Your Current Skills</p>
        <div class="flex flex-wrap gap-2">
          {['React', 'JavaScript', 'CSS', 'HTML', 'Git', 'REST APIs'].map((skill) => (
            <span class="rounded-lg border border-[#e8eaed] bg-white px-3 py-1.5 text-sm font-medium text-navy">
              {skill}
            </span>
          ))}
        </div>
      </div>

      <!-- Target Role -->
      <div class="rounded-2xl border border-navy/10 bg-navy p-6">
        <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-white/40">Target Role</p>
        <p class="mb-4 text-base font-semibold text-white">Senior Full Stack Engineer</p>
        <div class="flex flex-wrap gap-2">
          {['React', 'TypeScript', 'Node.js', 'AWS', 'Docker', 'PostgreSQL'].map((skill) => (
            <span class="rounded-lg bg-white/10 px-3 py-1.5 text-sm font-medium text-white">
              {skill}
            </span>
          ))}
        </div>
      </div>

      <!-- Skill Gaps -->
      <div class="rounded-2xl border border-orange/20 bg-apricot p-6">
        <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-orange">Skills to Develop</p>
        <div class="flex flex-wrap gap-2">
          {['TypeScript', 'Node.js', 'AWS', 'Docker', 'PostgreSQL'].map((skill) => (
            <span class="rounded-lg border border-orange/20 bg-white px-3 py-1.5 text-sm font-medium text-orange">
              {skill}
            </span>
          ))}
        </div>
        <p class="mt-4 text-sm text-orange/70">5 skills identified</p>
      </div>

    </div>

    <!-- Learning Timeline -->
    <div class="rounded-2xl border border-[#e8eaed] bg-surface p-8">
      <p class="mb-8 text-base font-semibold text-navy">Your Personalized Learning Plan</p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">

        <div class="relative rounded-xl bg-white p-5 border border-[#e8eaed]">
          <div class="mb-3 flex items-center justify-between">
            <span class="rounded-md bg-orange/10 px-2.5 py-1 text-xs font-semibold text-orange">Month 1</span>
          </div>
          <h4 class="text-base font-semibold text-navy">TypeScript</h4>
          <p class="mt-1 text-sm text-muted">Type safety, generics, utility types</p>
        </div>

        <div class="relative rounded-xl bg-white p-5 border border-[#e8eaed]">
          <div class="mb-3 flex items-center justify-between">
            <span class="rounded-md bg-[#f4f4f5] px-2.5 py-1 text-xs font-semibold text-muted">Month 2</span>
          </div>
          <h4 class="text-base font-semibold text-navy">Node.js</h4>
          <p class="mt-1 text-sm text-muted">Runtime, async patterns, APIs</p>
        </div>

        <div class="relative rounded-xl bg-white p-5 border border-[#e8eaed]">
          <div class="mb-3 flex items-center justify-between">
            <span class="rounded-md bg-[#f4f4f5] px-2.5 py-1 text-xs font-semibold text-muted">Month 3</span>
          </div>
          <h4 class="text-base font-semibold text-navy">Docker</h4>
          <p class="mt-1 text-sm text-muted">Containers, Compose, deployments</p>
        </div>

        <div class="relative rounded-xl bg-white p-5 border border-[#e8eaed]">
          <div class="mb-3 flex items-center justify-between">
            <span class="rounded-md bg-[#f4f4f5] px-2.5 py-1 text-xs font-semibold text-muted">Month 4</span>
          </div>
          <h4 class="text-base font-semibold text-navy">AWS</h4>
          <p class="mt-1 text-sm text-muted">S3, EC2, Lambda, IAM basics</p>
        </div>

      </div>
    </div>

  </div>
</section>
