---
---

<section class="relative overflow-hidden bg-white py-20 lg:py-28">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="grid items-center gap-16 lg:grid-cols-2">

      <!-- Left: Copy -->
      <div class="flex flex-col gap-8">
        <div class="inline-flex w-fit items-center gap-2 rounded-full border border-[#e8eaed] bg-surface px-3.5 py-1.5">
          <span class="size-1.5 rounded-full bg-orange"></span>
          <span class="text-xs font-medium tracking-wide text-muted uppercase">Invite-Only Beta</span>
        </div>

        <div class="flex flex-col gap-5">
          <h1 class="text-[56px] font-semibold leading-[1.08] tracking-[-0.02em] text-navy lg:text-[68px]">
            Turn Your CV Into<br />a Career Growth<br />
            <span class="text-orange">Plan.</span>
          </h1>
          <p class="max-w-[480px] text-lg leading-relaxed text-muted">
            Upload your CV and paste any job description or URL. We analyze
            your current skills, identify exactly what's missing for your target
            role, and generate a structured learning roadmap.
          </p>
        </div>

        <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
          <a
            href="#waitlist"
            class="inline-flex items-center justify-center rounded-xl bg-orange px-6 py-3.5 text-base font-medium text-white shadow-lg shadow-orange/20 transition-all hover:shadow-xl hover:shadow-orange/30 hover:-translate-y-px"
          >
            Get Free Early Access
          </a>
          <a
            href="#skill-gap"
            class="inline-flex items-center justify-center gap-2 rounded-xl border border-[#e8eaed] px-6 py-3.5 text-base font-medium text-navy transition-colors hover:bg-surface"
          >
            View Example Roadmap
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <p class="text-sm text-muted">
          Free to use. Invite-only access. New users are admitted gradually.
          Already have access?{' '}
          <a href="https://app.uplerr.com" class="font-medium text-navy underline underline-offset-4 hover:text-orange transition-colors">
            Log in
          </a>
        </p>
      </div>

      <!-- Right: Product Mockup -->
      <div class="flex flex-col gap-4">

        <!-- Analysis Card -->
        <div class="rounded-2xl border border-[#e8eaed] bg-white shadow-xl shadow-navy/[0.06] overflow-hidden">
          <div class="flex items-center justify-between border-b border-[#e8eaed] px-5 py-4">
            <div>
              <p class="text-sm font-semibold text-navy">Senior Frontend Engineer</p>
              <p class="mt-0.5 text-xs text-muted">Stripe · Remote</p>
            </div>
            <div class="flex items-center gap-1.5 rounded-full bg-orange/10 px-3 py-1 text-xs font-medium text-orange">
              <span class="size-1.5 animate-pulse rounded-full bg-orange"></span>
              Analysing
            </div>
          </div>

          <div class="divide-y divide-[#f4f4f5] px-5">
            <!-- Step 1 -->
            <div class="flex items-center gap-3 py-3.5">
              <div class="flex size-6 shrink-0 items-center justify-center rounded-full bg-green-100">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                  <path d="M2 5l2.5 2.5L8 3" stroke="#16a34a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <span class="text-sm text-navy">CV Upload</span>
              <span class="ml-auto text-xs text-muted">Complete</span>
            </div>
            <!-- Step 2 -->
            <div class="flex items-center gap-3 py-3.5">
              <div class="flex size-6 shrink-0 items-center justify-center rounded-full bg-green-100">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                  <path d="M2 5l2.5 2.5L8 3" stroke="#16a34a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <span class="text-sm text-navy">Skill Extraction</span>
              <span class="ml-auto text-xs text-muted">Complete</span>
            </div>
            <!-- Step 3 — active -->
            <div class="flex items-center gap-3 py-3.5">
              <div class="flex size-6 shrink-0 items-center justify-center rounded-full bg-orange/10">
                <span class="size-2 animate-pulse rounded-full bg-orange"></span>
              </div>
              <span class="text-sm font-medium text-navy">Gap Analysis</span>
              <span class="ml-auto text-xs font-medium text-orange">Running…</span>
            </div>
            <!-- Step 4 -->
            <div class="flex items-center gap-3 py-3.5">
              <div class="flex size-6 shrink-0 items-center justify-center rounded-full bg-[#f4f4f5]">
                <span class="size-2 rounded-full bg-[#d1d5db]"></span>
              </div>
              <span class="text-sm text-muted">Roadmap Generation</span>
              <span class="ml-auto text-xs text-[#d1d5db]">Queued</span>
            </div>
            <!-- Step 5 -->
            <div class="flex items-center gap-3 py-3.5">
              <div class="flex size-6 shrink-0 items-center justify-center rounded-full bg-[#f4f4f5]">
                <span class="size-2 rounded-full bg-[#d1d5db]"></span>
              </div>
              <span class="text-sm text-muted">Role Readiness</span>
              <span class="ml-auto text-xs text-[#d1d5db]">Queued</span>
            </div>
          </div>

          <!-- Progress bar -->
          <div class="px-5 py-4 border-t border-[#e8eaed]">
            <div class="mb-1.5 flex justify-between text-xs text-muted">
              <span>Progress</span>
              <span>40%</span>
            </div>
            <div class="h-1.5 rounded-full bg-[#f4f4f5] overflow-hidden">
              <div class="h-full w-[40%] rounded-full bg-orange transition-all duration-1000"></div>
            </div>
          </div>
        </div>

        <!-- Roadmap preview — locked -->
        <div class="relative rounded-2xl border border-[#e8eaed] bg-white shadow-lg shadow-navy/[0.04] overflow-hidden">
          <!-- Blur overlay -->
          <div class="absolute inset-0 z-10 flex flex-col items-center justify-center gap-3 bg-white/70 backdrop-blur-[6px]">
            <div class="flex items-center gap-2 rounded-full border border-[#e8eaed] bg-white px-4 py-2 shadow-sm">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <rect x="2" y="6" width="10" height="7" rx="1.5" stroke="#6b7280" stroke-width="1.2"/>
                <path d="M4.5 6V4.5a2.5 2.5 0 0 1 5 0V6" stroke="#6b7280" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
              <span class="text-xs font-medium text-muted">Pending access · Join waitlist to unlock</span>
            </div>
          </div>

          <div class="border-b border-[#e8eaed] px-5 py-4">
            <p class="text-sm font-semibold text-navy">Your Learning Roadmap</p>
            <p class="mt-0.5 text-xs text-muted">4 months · 5 skill areas</p>
          </div>
          <div class="divide-y divide-[#f4f4f5] px-5">
            <div class="flex items-center justify-between py-3.5">
              <div class="flex items-center gap-3">
                <div class="flex size-7 items-center justify-center rounded-lg bg-[#f4f4f5] text-xs font-semibold text-navy">1</div>
                <span class="text-sm text-navy">TypeScript Mastery</span>
              </div>
              <span class="text-xs text-muted">Month 1</span>
            </div>
            <div class="flex items-center justify-between py-3.5">
              <div class="flex items-center gap-3">
                <div class="flex size-7 items-center justify-center rounded-lg bg-[#f4f4f5] text-xs font-semibold text-navy">2</div>
                <span class="text-sm text-navy">Node.js & REST APIs</span>
              </div>
              <span class="text-xs text-muted">Month 2</span>
            </div>
            <div class="flex items-center justify-between py-3.5 opacity-40">
              <div class="flex items-center gap-3">
                <div class="flex size-7 items-center justify-center rounded-lg bg-[#f4f4f5] text-xs font-semibold text-navy">3</div>
                <span class="text-sm text-navy">Docker & Containers</span>
              </div>
              <span class="text-xs text-muted">Month 3</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
