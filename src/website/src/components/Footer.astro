---
---

<footer class="border-t border-[#e8eaed] bg-white py-16">
  <div class="mx-auto max-w-[1200px] px-6">

    <!-- Top row -->
    <div class="mb-12 grid gap-10 lg:grid-cols-4">

      <!-- Brand -->
      <div class="lg:col-span-2 flex flex-col gap-4">
        <a href="/" class="text-xl font-semibold tracking-tight text-navy">
          uplerr<span class="text-orange">.</span>
        </a>
        <p class="max-w-xs text-sm leading-relaxed text-muted">
          A career intelligence platform that helps developers understand their
          skill gaps and build a structured path to their target role.
        </p>
        <p class="text-xs text-muted/60">Open source · Free to self-host</p>
      </div>

      <!-- Product -->
      <div class="flex flex-col gap-4">
        <p class="text-xs font-semibold uppercase tracking-widest text-navy">Product</p>
        <nav class="flex flex-col gap-3">
          <a href="#how-it-works" class="text-sm text-muted hover:text-navy transition-colors">How It Works</a>
          <a href="#features" class="text-sm text-muted hover:text-navy transition-colors">Features</a>
          <a href="#skill-gap" class="text-sm text-muted hover:text-navy transition-colors">Example Roadmap</a>
          <a href="#self-host" class="text-sm text-muted hover:text-navy transition-colors">Self-host</a>
        </nav>
      </div>

      <!-- GitHub -->
      <div class="flex flex-col gap-4">
        <p class="text-xs font-semibold uppercase tracking-widest text-navy">Open Source</p>
        <nav class="flex flex-col gap-3">
          <a href="https://github.com/samipsamip/uplerr" target="_blank" rel="noopener noreferrer" class="text-sm text-muted hover:text-navy transition-colors">GitHub</a>
          <a href="https://github.com/samipsamip/uplerr/blob/main/prompts/README.md" target="_blank" rel="noopener noreferrer" class="text-sm text-muted hover:text-navy transition-colors">Prompt Setup</a>
        </nav>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col items-start justify-between gap-4 border-t border-[#e8eaed] pt-8 sm:flex-row sm:items-center">
      <p class="text-xs text-muted/60">
        &copy; {new Date().getFullYear()} Uplerr. All rights reserved.
      </p>
      <p class="text-xs text-muted/60">
        Built for developers who take their career seriously.
      </p>
    </div>

  </div>
</footer>
