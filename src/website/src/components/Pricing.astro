---
---

<section id="self-host" class="bg-surface py-[120px]">
  <div class="mx-auto max-w-[1200px] px-6">

    <div class="mb-16 flex flex-col gap-4">
      <p class="text-sm font-medium uppercase tracking-widest text-orange">Open Source</p>
      <h2 class="max-w-lg text-[42px] font-semibold leading-[1.1] tracking-tight text-navy">
        Free to run. Yours to own.
      </h2>
      <p class="max-w-xl text-base leading-relaxed text-muted">
        There is no hosted version of Uplerr anymore. You get the full source,
        run it with Docker Compose, and own every part of it.
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">

      <!-- What you need -->
      <div class="flex flex-col gap-6 rounded-2xl border border-[#e8eaed] bg-white p-8">
        <h3 class="text-lg font-semibold text-navy">What you need</h3>
        <ul class="flex flex-col gap-5">
          <li class="flex items-start gap-4">
            <div class="mt-0.5 flex size-8 shrink-0 items-center justify-center rounded-lg bg-navy text-white text-xs font-semibold">1</div>
            <div>
              <p class="text-sm font-semibold text-navy">Braintrust account</p>
              <p class="mt-0.5 text-sm text-muted">For LLM prompt routing and logging. Create your prompts from the templates in <code class="rounded bg-surface px-1.5 py-0.5 text-xs">prompts/</code>.</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <div class="mt-0.5 flex size-8 shrink-0 items-center justify-center rounded-lg bg-navy text-white text-xs font-semibold">2</div>
            <div>
              <p class="text-sm font-semibold text-navy">Cloudflare R2 bucket</p>
              <p class="mt-0.5 text-sm text-muted">For storing uploaded resume PDFs. Free tier is more than enough for personal use.</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <div class="mt-0.5 flex size-8 shrink-0 items-center justify-center rounded-lg bg-surface border border-[#e8eaed] text-muted text-xs font-semibold">3</div>
            <div>
              <p class="text-sm font-semibold text-navy">Resend account <span class="font-normal text-muted">(optional)</span></p>
              <p class="mt-0.5 text-sm text-muted">For email verification. If you skip this, verification links are printed to the API logs instead.</p>
            </div>
          </li>
        </ul>
      </div>

      <!-- How to set it up -->
      <div class="flex flex-col gap-6 rounded-2xl bg-navy p-8">
        <h3 class="text-lg font-semibold text-white">How to set it up</h3>
        <div class="flex flex-col gap-4">
          <div class="flex flex-col gap-1.5">
            <p class="text-xs font-semibold uppercase tracking-widest text-white/40">Step 1</p>
            <code class="rounded-lg bg-white/10 px-4 py-3 text-sm font-mono text-white">git clone https://github.com/samipsamip/uppler</code>
          </div>
          <div class="flex flex-col gap-1.5">
            <p class="text-xs font-semibold uppercase tracking-widest text-white/40">Step 2</p>
            <code class="rounded-lg bg-white/10 px-4 py-3 text-sm font-mono text-white">cp .env.example .env<br/># add your API keys</code>
          </div>
          <div class="flex flex-col gap-1.5">
            <p class="text-xs font-semibold uppercase tracking-widest text-white/40">Step 3</p>
            <code class="rounded-lg bg-white/10 px-4 py-3 text-sm font-mono text-white">docker compose up --build</code>
          </div>
        </div>
        <a
          href="https://github.com/samipsamip/uppler"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-auto inline-flex items-center justify-center gap-2 rounded-xl bg-orange px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-orange/25 transition-all hover:opacity-90"
        >
          <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          View on GitHub
        </a>
      </div>

    </div>

  </div>
</section>
