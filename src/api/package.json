{
	"name": "@uppler/api",
	"type": "module",
	"scripts": {
		"dev": "tsx watch --env-file=.env src/index.ts",
		"build": "tsc",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:seed": "tsx --env-file=.env src/seed/skills.seed.ts",
		"start": "node dist/index.js",
		"lint": "eslint . --fix",
		"typecheck": "tsc --noEmit",
		"format": "prettier --write .",
		"check": "eslint . && prettier --check .",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"approve": "tsx --env-file=.env src/scripts/send-approval.ts"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.98.1",
		"@aws-sdk/client-s3": "^3.1057.0",
		"@aws-sdk/s3-request-presigner": "^3.1057.0",
		"@hono/node-server": "^1.19.14",
		"@hono/zod-validator": "^0.8.0",
		"@langfuse/client": "^5.4.1",
		"@mozilla/readability": "^0.6.0",
		"@uppler/types": "workspace:*",
		"better-auth": "^1.6.13",
		"braintrust": "^3.14.0",
		"dompurify": "^3.4.7",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.23",
		"jsdom": "^29.1.1",
		"pg": "^8.21.0",
		"pino": "^10.3.1",
		"playwright": "^1.60.0",
		"resend": "^6.12.4",
		"unpdf": "^1.6.2",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@electric-sql/pglite": "^0.4.6",
		"@types/jsdom": "^28.0.3",
		"@types/node": "^20.19.41",
		"@types/pg": "^8.20.0",
		"@vitest/coverage-v8": "4.1.7",
		"@vitest/ui": "4.1.7",
		"drizzle-kit": "^0.31.10",
		"tsx": "^4.22.4",
		"typescript": "^5.9.3",
		"vitest": "^4.1.7"
	}
}
