{
	"name": "@uppler/api",
	"type": "module",
	"scripts": {
		"dev": "tsx watch --env-file=.env src/index.ts",
		"build": "tsc",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"start": "node dist/index.js",
		"lint": "eslint . --fix",
		"typecheck": "tsc --noEmit",
		"format": "prettier --write .",
		"check": "eslint . && prettier --check ."
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1052.0",
		"@aws-sdk/s3-request-presigner": "^3.1052.0",
		"@hono/node-server": "^1.19.14",
		"better-auth": "^1.6.10",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.18",
		"pdf-parse": "^2.4.5",
		"pg": "^8.20.0",
		"resend": "^6.12.3"
	},
	"devDependencies": {
		"@types/node": "^20.19.40",
		"@types/pg": "^8.20.0",
		"drizzle-kit": "^0.31.10",
		"tsx": "^4.21.0",
		"typescript": "^5.8.3"
	}
}
