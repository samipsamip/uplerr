{
	"$schema": "https://turborepo.dev/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"dev": {
			"persistent": true,
			"cache": true
		},
		"lint": {
			"outputs": []
		},
		"format": {
			"outputs": []
		},
		"check": {
			"outputs": []
		},
		"typecheck": {
			"dependsOn": ["^typecheck"],
			"outputs": []
		},
		"test": {
			"outputs": ["coverage/**"]
		},
		"test:watch": {
			"persistent": true,
			"cache": false
		}
	}
}
